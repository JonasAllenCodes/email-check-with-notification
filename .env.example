# IMAP Connection
IMAP_HOST=imap.yourprovider.com
IMAP_PORT=993
IMAP_EMAIL=your.email@yourdomain.com
IMAP_PASSWORD=your-app-password

# Search Criteria
EMAIL_FOLDER=INBOX
EMAIL_SENDER=
EMAIL_SUBJECT=
EMAIL_MATCH_RULE=and
SEARCH_LOOKBACK_HOURS=24

# Notification
NTFY_URL=https://ntfy.sh/your-secret-topic
NTFY_TITLE=Email Check
NOTIFY_ON_FOUND=true
NOTIFY_ON_NOT_FOUND=true

# Notification Messages (leave empty for defaults)
# Supports: {count}, {lookback_hours}
MESSAGE_ON_FOUND=
# Supports: {lookback_hours}
MESSAGE_ON_NOT_FOUND=
# Supports: {sender}, {subject}, {date}
MESSAGE_EMAIL_DETAIL=

# Toggle per-email detail notifications
NOTIFY_EMAIL_DETAILS=true
